# AIOS Environment Configuration

# Core App Settings
PROJECT_NAME="AIOS - Artificial Intelligence Operating System"
ENVIRONMENT="development" # development | staging | production | testing
DEBUG=true
API_V1_STR="/api/v1"
SECRET_KEY="aios_super_secret_enterprise_production_key_change_in_prod"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration (PostgreSQL Async)
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aios_user
POSTGRES_PASSWORD=aios_secure_pass_2026
POSTGRES_DB=aios_db
DATABASE_URL="postgresql+asyncpg://aios_user:aios_secure_pass_2026@localhost:5432/aios_db"

# Redis Cache & Celery Broker
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL="redis://localhost:6379/0"

# Vector Database (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=""

# Knowledge Graph (Neo4j)
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER=neo4j
NEO4J_PASSWORD=aios_neo4j_password_2026

# MinIO Object Storage
MINIO_ENDPOINT="localhost:9000"
MINIO_ACCESS_KEY="aios_minio_admin"
MINIO_SECRET_KEY="aios_minio_secure_secret"
MINIO_BUCKET_DOCUMENTS="aios-documents"

# AI Model Provider API Keys
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
OPENROUTER_API_KEY=""

# CORS Setup
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]'
